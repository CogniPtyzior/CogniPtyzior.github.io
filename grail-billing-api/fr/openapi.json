{
  "openapi": "3.0.3",
  "info": {
    "title": "Référence API Grail Billing",
    "version": "1.0.0",
    "description": "## Vue d'ensemble\n\nGrail Billing est une API de facturation de démonstration construite avec Express, TypeScript, MongoDB et Mongoose. Elle met en avant une architecture hexagonale, du DDD pragmatique, des contexts bornés, une authentification JWT, des données de démo déterministes, de l'observabilité runtime et des pratiques de déploiement Docker.\n\n## Parcours de lecture\n\n1. Demander un Bearer token avec `POST /api/auth/token`.\n2. Utiliser le token sur les routes protégées `/api/*`.\n3. Créer companies, customers, tax rates et products.\n4. Créer une facture brouillon.\n5. L'émettre pour verrouiller les informations et assigner une référence de facture.\n6. Enregistrer les paiements et relire le statut mis à jour."
  },
  "tags": [
    {
      "name": "Auth",
      "description": "Émission de tokens et gestion admin-only des utilisateurs API pour les accès protégés."
    },
    {
      "name": "Observability",
      "description": "Endpoints publics de liveness/readiness et métriques runtime en mémoire, accessibles uniquement aux admins."
    },
    {
      "name": "Billing / Invoices",
      "description": "Workflow central de facturation : brouillons, émission officielle, informations client et émetteur verrouillées, paiements et statut consultable."
    },
    {
      "name": "Companies",
      "description": "Compagnies émettrices utilisées par Billing pour figer l'identité légale et les mentions lors de la finalisation."
    },
    {
      "name": "Customers",
      "description": "Clients facturés utilisés par Billing pour figer l'identité client et l'adresse de facturation."
    },
    {
      "name": "Catalog / Products",
      "description": "Produits sélectionnables dans les lignes de facture, avec référence de taux de taxe par défaut et filtrage actif."
    },
    {
      "name": "Reference Data / Tax Rates",
      "description": "Référentiels de taux de taxe utilisés par les produits et les lignes de facture. La démo inclut une TVA française déterministe."
    }
  ],
  "security": [
    {
      "BearerToken": []
    }
  ],
  "components": {
    "securitySchemes": {
      "BearerToken": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Paste the access token returned by POST /api/auth/token."
      }
    }
  },
  "paths": {
    "/api/auth/token": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Se connecter et obtenir un token",
        "description": "Authentifie un utilisateur et retourne un Bearer token. Utilisez ce token dans l'en-tête Authorization pour appeler les endpoints protégés.",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "username",
                  "password"
                ],
                "properties": {
                  "username": {
                    "type": "string",
                    "example": "demo"
                  },
                  "password": {
                    "type": "string",
                    "example": "<AUTH_DEMO_PASSWORD>"
                  }
                }
              },
              "example": {
                "username": "demo",
                "password": "<AUTH_DEMO_PASSWORD>"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Bearer token issued",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "accessToken",
                    "tokenType",
                    "expiresIn"
                  ],
                  "properties": {
                    "accessToken": {
                      "type": "string"
                    },
                    "tokenType": {
                      "type": "string",
                      "example": "Bearer"
                    },
                    "expiresIn": {
                      "type": "number",
                      "example": 14400
                    }
                  }
                },
                "example": {
                  "accessToken": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
                  "tokenType": "Bearer",
                  "expiresIn": 14400
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials"
          },
          "429": {
            "description": "Too many token requests"
          }
        },
        "operationId": "issueBearerToken"
      }
    },
    "/api/auth/users": {
      "get": {
        "tags": [
          "Auth"
        ],
        "summary": "Consulter les comptes API",
        "description": "Retourne les comptes API capables de s'authentifier sur la démo. Cet endpoint est réservé aux administrateurs.",
        "responses": {
          "200": {
            "description": "User list",
            "content": {
              "application/json": {
                "example": {
                  "data": [
                    {
                      "id": "user-admin",
                      "username": "admin",
                      "role": "admin",
                      "active": true
                    },
                    {
                      "id": "user-demo",
                      "username": "demo",
                      "role": "demo",
                      "active": true
                    }
                  ]
                }
              }
            }
          },
          "403": {
            "description": "Admin role required"
          }
        },
        "operationId": "listApiUsers"
      },
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Créer un compte API",
        "description": "Crée un compte API avec un rôle et un statut actif. Le mot de passe est hashé avant stockage.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": {
                "username": "auditor",
                "password": "<new-user-password>",
                "role": "demo",
                "active": true
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User created"
          },
          "403": {
            "description": "Admin role required"
          },
          "409": {
            "description": "Username already exists"
          }
        },
        "operationId": "createApiUser"
      }
    },
    "/api/auth/users/{userId}": {
      "patch": {
        "tags": [
          "Auth"
        ],
        "summary": "Modifier un compte API",
        "description": "Met à jour un compte API, par exemple pour changer son mot de passe, son rôle ou désactiver l'accès.",
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "user-auditor"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": {
                "active": true
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User updated"
          },
          "403": {
            "description": "Admin role required"
          },
          "404": {
            "description": "User not found"
          }
        },
        "operationId": "updateApiUser"
      }
    },
    "/health": {
      "get": {
        "tags": [
          "Observability"
        ],
        "summary": "Vérifier que l'API répond",
        "description": "Vérifie rapidement que le processus HTTP répond.",
        "security": [],
        "responses": {
          "200": {
            "description": "API process is alive",
            "content": {
              "application/json": {
                "example": {
                  "status": "ok"
                }
              }
            }
          }
        },
        "operationId": "checkLiveness"
      }
    },
    "/ready": {
      "get": {
        "tags": [
          "Observability"
        ],
        "summary": "Vérifier que l'API est prête",
        "description": "Vérifie que l'application a terminé son démarrage et peut joindre MongoDB avant de recevoir du trafic.",
        "security": [],
        "responses": {
          "200": {
            "description": "API is ready to serve traffic",
            "content": {
              "application/json": {
                "example": {
                  "status": "ready",
                  "checks": {
                    "mongo": "ok",
                    "bootstrap": "ok"
                  }
                }
              }
            }
          },
          "503": {
            "description": "API process is alive but not ready",
            "content": {
              "application/json": {
                "example": {
                  "status": "not_ready",
                  "checks": {
                    "mongo": "unavailable",
                    "bootstrap": "pending"
                  }
                }
              }
            }
          }
        },
        "operationId": "checkReadiness"
      }
    },
    "/api/metrics": {
      "get": {
        "tags": [
          "Observability"
        ],
        "summary": "Consulter les métriques runtime",
        "description": "Retourne les compteurs opérationnels du processus API courant: trafic HTTP, authentification et rate limiting. Cet endpoint est réservé aux administrateurs.",
        "security": [
          {
            "BearerToken": []
          }
        ],
        "responses": {
          "200": {
            "description": "Runtime metrics report",
            "content": {
              "application/json": {
                "example": {
                  "startedAt": "2026-06-16T20:00:00.000Z",
                  "uptimeSeconds": 3600,
                  "http": {
                    "requestsTotal": 42,
                    "errorsTotal": 1,
                    "averageDurationMs": 18,
                    "responsesByStatus": {
                      "200": 35,
                      "401": 3,
                      "500": 1
                    },
                    "lastRequestAt": "2026-06-16T21:00:00.000Z"
                  },
                  "auth": {
                    "tokensIssuedTotal": 4,
                    "invalidCredentialsTotal": 1
                  },
                  "rateLimit": {
                    "hitsTotal": 0
                  },
                  "demoReset": {
                    "lastRunAt": "2026-06-16T20:30:00.000Z",
                    "lastStatus": "success"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Missing or invalid Bearer token"
          },
          "403": {
            "description": "Authenticated user is not an admin"
          }
        },
        "operationId": "readRuntimeMetrics"
      }
    },
    "/api/billing/invoices": {
      "get": {
        "tags": [
          "Billing / Invoices"
        ],
        "summary": "Rechercher des factures",
        "description": "Recherche les factures avec des filtres optionnels: émetteur, client, statut de facture, statut de paiement et pagination.",
        "parameters": [
          {
            "name": "companyId",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "example": "company-aurora"
          },
          {
            "name": "customerId",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "example": "customer-nova"
          },
          {
            "name": "status",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "draft",
                "issued"
              ]
            },
            "example": "draft"
          },
          {
            "name": "paymentStatus",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "unpaid",
                "partially_paid",
                "paid"
              ]
            },
            "example": "unpaid"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "number",
              "default": 50
            },
            "example": 50
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "schema": {
              "type": "number",
              "default": 0
            },
            "example": 0
          }
        ],
        "responses": {
          "200": {
            "description": "Invoice list",
            "content": {
              "application/json": {
                "example": {
                  "data": [
                    {
                      "id": "invoice-example-issued",
                      "status": "issued",
                      "paymentStatus": "unpaid",
                      "companyId": "company-aurora",
                      "customerId": "customer-nova",
                      "totalIncludingTax": 1800,
                      "currency": "EUR"
                    }
                  ],
                  "paging": {
                    "limit": 50,
                    "offset": 0
                  }
                }
              }
            }
          }
        },
        "operationId": "listInvoices"
      },
      "post": {
        "tags": [
          "Billing / Invoices"
        ],
        "summary": "Créer une facture brouillon",
        "description": "Crée une facture brouillon encore modifiable avant son émission officielle.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": {
                "customerId": "customer-nova",
                "companyId": "company-aurora",
                "description": "Invoice for API development services",
                "lines": [
                  {
                    "productId": "product-api-platform",
                    "label": "API development",
                    "description": "Node.js Express billing API development",
                    "quantity": 2,
                    "unitPrice": 750,
                    "taxRate": 20
                  }
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Draft invoice created"
          },
          "400": {
            "description": "Invalid body"
          }
        },
        "operationId": "createDraftInvoice"
      }
    },
    "/api/billing/invoices/{invoiceId}": {
      "get": {
        "tags": [
          "Billing / Invoices"
        ],
        "summary": "Consulter une facture",
        "description": "Retourne la facture telle qu'elle est exposée aux consommateurs de l'API: statut, montants, client, émetteur et informations légales une fois émise.",
        "parameters": [
          {
            "name": "invoiceId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "invoice-demo-issued"
          }
        ],
        "responses": {
          "200": {
            "description": "Invoice details",
            "content": {
              "application/json": {
                "example": {
                  "id": "invoice-example-issued",
                  "status": "issued",
                  "reference": "2026-0001",
                  "customerSnapshot": {
                    "id": "customer-nova",
                    "name": "Nova Retail"
                  },
                  "companySnapshot": {
                    "id": "company-aurora",
                    "legalName": "Aurora Consulting SAS"
                  },
                  "totals": {
                    "excludingTax": 1500,
                    "tax": 300,
                    "includingTax": 1800,
                    "currency": "EUR"
                  }
                }
              }
            }
          },
          "404": {
            "description": "Invoice not found"
          }
        },
        "operationId": "getInvoiceDetails"
      }
    },
    "/api/billing/invoices/{invoiceId}/finalize": {
      "post": {
        "tags": [
          "Billing / Invoices"
        ],
        "summary": "Émettre une facture brouillon",
        "description": "Émet une facture brouillon. L'opération attribue la référence officielle, verrouille les informations client et émetteur, puis rend la facture immuable.",
        "parameters": [
          {
            "name": "invoiceId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "invoice-demo-draft"
          }
        ],
        "responses": {
          "204": {
            "description": "Invoice finalized"
          },
          "404": {
            "description": "Invoice not found"
          },
          "422": {
            "description": "Business rule error"
          }
        },
        "operationId": "finalizeInvoice"
      }
    },
    "/api/billing/invoices/{invoiceId}/payments": {
      "post": {
        "tags": [
          "Billing / Invoices"
        ],
        "summary": "Enregistrer un paiement",
        "description": "Enregistre un paiement sur une facture émise. La référence externe permet d'éviter l'enregistrement accidentel d'un doublon.",
        "parameters": [
          {
            "name": "invoiceId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "invoice-demo-issued"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": {
                "amount": 1800,
                "method": "bank_transfer",
                "paidAt": "2026-06-15T10:00:00.000Z",
                "externalReference": "BANK-TRANSFER-001"
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Payment registered"
          },
          "400": {
            "description": "Invalid body"
          },
          "404": {
            "description": "Invoice not found"
          },
          "422": {
            "description": "Business rule error"
          }
        },
        "operationId": "registerInvoicePayment"
      }
    },
    "/api/catalog/products": {
      "get": {
        "tags": [
          "Catalog / Products"
        ],
        "summary": "Lister les produits facturables",
