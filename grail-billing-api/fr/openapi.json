    "/api/reference-data/tax-rates": {
      "get": {
        "tags": [
          "Reference Data / Tax Rates"
        ],
        "summary": "Lister les taux de taxe",
        "description": "Liste les taux de taxe disponibles pour les produits et lignes de facture, avec filtre optionnel par pays ou statut actif.",
        "parameters": [
          {
