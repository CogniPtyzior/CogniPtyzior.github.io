      "post": {
        "tags": [
          "Catalog / Products"
        ],
        "summary": "Créer un produit facturable",
        "description": "Crée un produit facturable avec un prix par défaut, une devise et une référence de taux de taxe.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": {
                "id": "product-api-platform",
                "name": "Architecture workshop",
                "description": "DDD and hexagonal architecture workshop",
                "unitPrice": 750,
                "currency": "EUR",
                "defaultTaxRateId": "tax-fr-vat-20",
                "active": true
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Product created"
          },
          "400": {
            "description": "Invalid body"
          }
        },
        "operationId": "createProduct"
      }
    },
    "/api/catalog/products/{productId}": {
      "get": {
        "tags": [
          "Catalog / Products"
        ],
        "summary": "Consulter un produit facturable",
        "description": "Retourne un produit ou service facturable.",
        "parameters": [
          {
            "name": "productId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "product-api-platform"
          }
        ],
        "responses": {
          "200": {
            "description": "Product details"
          },
          "404": {
            "description": "Product not found"
          }
        },
        "operationId": "getProduct"
      }
    },
    "/api/companies": {
      "get": {
        "tags": [
